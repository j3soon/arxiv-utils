{
  "name": "usenix-utils",
  "version": "1.0.0",
  "description": "Easy access on USENIX! Auto-rename presentation/PDF tabs to the paper title, and quick navigation via button/hotkey.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [{
    "matches": [
      "*://usenix.org/system/files/*",
      "*://www.usenix.org/system/files/*",
      "*://usenix.org/conference/*/presentation/*",
      "*://www.usenix.org/conference/*/presentation/*"
    ],
    "js": [ "content.js" ],
    "run_at": "document_end"
  }],
  "action": {
    "default_icon": {
      "19": "icon19.png",
      "38": "icon38.png"
    },
    "default_title": "Open USENIX Presentation / PDF"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A"
      }
    }
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "*://usenix.org/*",
    "*://www.usenix.org/*"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "manifest_version": 3
}
